# ============================================================
#  ChronosAI — Environment Configuration
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit the .env file to version control.
# ============================================================

# IBM Cloud API Key (from IBM Cloud IAM)
IBM_API_KEY=

# IBM Watsonx.ai Project ID
WATSONX_PROJECT_ID=

# Watsonx.ai endpoint URL (region-specific)
# e.g. https://us-south.ml.cloud.ibm.com
WATSONX_URL=

# Flask secret key (any random string)
FLASK_SECRET_KEY=your_flask_secret_key

# Flask environment (development | production)
FLASK_ENV=development

# Port to run the Flask app on
PORT=5000
